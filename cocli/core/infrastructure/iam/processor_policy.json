{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowRawDiscovery",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::${BUCKET_NAME}"
            ],
            "Condition": {
                "StringLike": {
                    "s3:prefix": [
                        "campaigns/*/raw/*",
                        "campaigns/*/indexes/*/wal/*"
                    ]
                }
            }
        },
        {
            "Sid": "AllowRawConsumption",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject"
            ],
            "Resource": [
                "arn:aws:s3:::${BUCKET_NAME}/campaigns/*/raw/*"
            ]
        },
        {
            "Sid": "AllowWalUpdate",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject"
            ],
            "Resource": [
                "arn:aws:s3:::${BUCKET_NAME}/campaigns/*/indexes/*/wal/*"
            ]
        }
    ]
}
